  "fixedCta": {
    "text": "Follow Tiny Agent. Tiny Agent helps you get better at using AI.",
    "start": 641.731,
    "outroStart": 641.731,
    "frameErrorSeconds": 0,
    "spokenEnd": 646.003187,
