      "id": "c06-p06-u01",
      "sceneId": "c06-p06",
      "chapterIndex": 5,
      "paragraphIndex": 5,
      "utteranceIndex": 0,
      "text": "每到一个里程碑，就更新状态并归档旧轨迹。",
      "gapBefore": 0.16,
      "audioDuration": 3.72,
      "audioStart": 263.003,
      "spokenStart": 263.166,
      "spokenEnd": 266.08,
      "actualGapBefore": 0.16
    },
    {
      "id": "c06-p06-u02",
      "sceneId": "c06-p06",
      "chapterIndex": 5,
      "paragraphIndex": 5,
      "utteranceIndex": 1,
      "text": "这样长期任务不会依赖一段不断膨胀的对话。",
      "gapBefore": 0.1,
      "audioDuration": 3.672,
      "audioStart": 266.019,
      "spokenStart": 266.18,
      "spokenEnd": 269.05,
      "actualGapBefore": 0.1
    },
