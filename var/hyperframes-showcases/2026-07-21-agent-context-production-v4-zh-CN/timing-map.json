      "id": "c06-p07-u02",
      "sceneId": "c06-p07",
      "chapterIndex": 5,
      "paragraphIndex": 6,
      "utteranceIndex": 1,
      "text": "也要足够完整，不让 AI 智能体猜关键约束。",
      "gapBefore": 0.1,
      "audioDuration": 3.744,
      "audioStart": 271.555,
      "spokenStart": 271.715,
      "spokenEnd": 274.645,
      "actualGapBefore": 0.1
    },
