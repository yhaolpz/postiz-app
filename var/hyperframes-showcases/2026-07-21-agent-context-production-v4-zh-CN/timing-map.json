      "id": "c06-p07-u01",
      "sceneId": "c06-p07",
      "chapterIndex": 5,
      "paragraphIndex": 6,
      "utteranceIndex": 0,
      "text": "上下文包要足够短，方便快速检查；",
      "gapBefore": 0.16,
      "audioDuration": 3.192,
      "audioStart": 269.053,
      "spokenStart": 269.21,
      "spokenEnd": 271.615,
      "actualGapBefore": 0.16
    },
