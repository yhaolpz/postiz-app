          "renderHuman": false,
          "coreObjectCount": 1,
          "start": 10.732,
          "end": 17.573
        },
        {
          "id": "c01-p04",
          "chapter": "前言",
          "chapterNumber": 1,
          "paragraphNumber": 4,
          "narration": "提示词越长，AI 智能体越可能追着旧细节跑。解决办法，是六部分高信号包：目标、规则、工具、示例、检索和状态。",
          "headline": "给 AI 智能体一个六部分高信号包",
          "coreLabel": "目标 · 规则 · 工具 · 示例 · 检索 · 状态",
          "type": "pack",
          "human": "idle",
          "agent": "handoff-left",
          "agentDirection": "left",
          "props": [
            {
              "id": "package"
            }
          ],
          "renderHuman": false,
          "coreObjectCount": 1,
          "start": 17.573,
          "end": 25.226
        },
        {
          "id": "c01-p05",
          "chapter": "前言",
          "chapterNumber": 1,
          "paragraphNumber": 5,
          "narration": "看注意力预算。原始历史塞满窗口时，目标会被挤小。只保留当前约束和有效证据，目标重新变大。其余信息移到窗口外，需要时再检索。",
          "headline": "AI 智能体看到更多，不等于信号更强",
          "coreLabel": "当前信号 68%",
          "type": "budget",
          "human": "idle",
          "agent": "reason-front",
          "agentDirection": "front",
          "props": [
            {
              "id": "document-stack"
            }
          ],
          "renderHuman": false,
          "coreObjectCount": 1,
          "start": 25.226,
          "end": 33.478
        },
        {
          "id": "c01-p06",
          "chapter": "前言",
          "chapterNumber": 1,
          "paragraphNumber": 6,
          "narration": "每一步只让 AI 智能体看见四件事：目标、约束、证据和当前状态。其他信息先留在窗口外，真正需要时再取，判断完成后再更新状态。",
          "headline": "AI 智能体每一步只保留四件事",
          "coreLabel": "目标 · 约束 · 证据 · 当前状态",
          "type": "list",
          "human": "idle",
          "agent": "verify-front",
          "agentDirection": "front",
          "props": [
            {
              "id": "task-list"
            }
          ],
          "renderHuman": false,
          "coreObjectCount": 1,
          "start": 33.478,
          "end": 42.338
        },
        {
          "id": "c01-p07",
          "chapter": "前言",
          "chapterNumber": 1,
          "paragraphNumber": 7,
          "narration": "核心判断只有一句：给 AI 智能体支持下一步行动的最小充分上下文，并随着长期任务持续更新。",
          "headline": "AI 智能体需要最小充分上下文",
          "coreLabel": "支持下一步行动",
          "type": "generic",
          "human": "idle",
          "agent": "present-left",
