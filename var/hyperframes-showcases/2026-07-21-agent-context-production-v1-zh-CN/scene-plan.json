        {
          "id": "c01-p03",
          "chapter": "前言",
          "chapterNumber": 1,
          "paragraphNumber": 3,
          "narration": "Anthropic 把上下文看成有限的注意力预算。窗口越满，下一步真正重要的信号越容易变弱，判断也会偏离当前目标。",
          "headline": "AI 智能体上下文是有限的注意力预算",
          "coreLabel": "注意力预算有限",
          "type": "authority",
          "human": "idle",
          "agent": "read-front",
