        {
          "id": "c03-p09",
          "chapter": "高信号输入",
          "chapterNumber": 3,
          "paragraphNumber": 9,
          "narration": "第三，用少量典型示例教会智能体真正的模式。",
          "headline": "3. 用典型示例展示模式",
          "coreLabel": "少量 · 多样 · 典型",
