        },
        {
          "id": "c04-p02",
          "chapter": "按需检索",
          "chapterNumber": 4,
          "paragraphNumber": 2,
          "narration": "按需检索只保留轻量引用，比如文件路径、已保存查询、网页链接、对象标识、目录名和时间戳。上下文里保留地图，到了某个判断确实需要证据时，再打开对应内容。",
          "headline": "上下文里先保留一张地图",
          "coreLabel": "路径 · 查询 · 标识 · 时间戳",
