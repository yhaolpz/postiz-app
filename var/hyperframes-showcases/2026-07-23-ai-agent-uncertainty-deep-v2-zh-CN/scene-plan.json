        },
        {
          "id": "c03-p03",
          "chapter": "判断：它到底知不知道",
          "chapterNumber": 3,
          "paragraphNumber": 3,
          "narration": "如果日期、对象、时间范围或术语不清，先澄清。不要问一串泛泛的问题，只追问真正会改变结论的最小信息，例如：你问的是今天的预计送达时间，还是下单时的承诺时间？",
          "headline": "缺少上下文，只追问会改变结论的信息",
          "coreLabel": "今天的预测，还是下单时承诺？",
          "type": "method",
          "layout": "human-agent-prop",
          "generatedArt": null,
          "temporaryGenerated": false,
          "generatedArtSide": null,
          "highlightSide": null,
          "motionType": "nudge",
          "recapPoints": null,
          "human": "ask-front",
          "humanDirection": "front",
          "agent": "ask-front",
