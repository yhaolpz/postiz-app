{
  "name": "tiny-agent-context-retention-sample-zh-cn",
  "private": true,
  "type": "module",
  "scripts": {
    "tts": "node build.mjs --tts",
    "build": "node build.mjs --compile",
    "check": "pnpm dlx hyperframes@0.7.64 check . --snapshots --frame-check=severity=error",
    "snapshot": "pnpm dlx hyperframes@0.7.64 snapshot . --at 0,2,5,12,20,30,45,58 --no-end --output snapshots",
    "render": "pnpm dlx hyperframes@0.7.64 render . --quality high --strict --quiet --workers 1 --output renders/retention-sample.zh-CN.mp4"
  },
  "devDependencies": {
    "hyperframes": "0.7.64"
  }
}
