[
  {
    "start": 0.1,
    "end": 2.88,
    "text": "你知道怎么给 AI 智能体高信号上下文吗？",
    "segmentId": "hook-question",
    "sceneId": "hook"
  },
  {
    "start": 2.8800000000000003,
    "end": 5.834,
    "text": "接下来我来告诉你，Anthropic 是怎么解决这个问题的。",
    "segmentId": "promise-method",
    "sceneId": "promise"
  },
  {
    "start": 5.833999999999999,
    "end": 8.879,
    "text": "全程都是高价值干货，让你成为更擅长使用 AI 的人。",
    "segmentId": "promise-benefit",
    "sceneId": "promise"
  },
  {
    "start": 8.878999999999998,
    "end": 12.167,
    "text": "内容较长，先点关注和收藏，之后随时回来复习。",
    "segmentId": "promise-save",
    "sceneId": "promise"
  },
  {
    "start": 12.166999999999998,
    "end": 14.538,
    "text": "Anthropic 把上下文看成有限的注意力预算。",
    "segmentId": "authority-budget",
    "sceneId": "authority"
  },
  {
    "start": 14.537999999999997,
    "end": 19.178,
    "text": "窗口越满，下一步真正重要的信号越容易变弱，判断也会偏离当前目标。",
    "segmentId": "authority-signal",
    "sceneId": "authority"
  },
  {
    "start": 19.178,
    "end": 22.04,
    "text": "提示词越长，AI 智能体越可能追着旧细节跑。",
    "segmentId": "artifact-pain",
    "sceneId": "artifact"
  },
  {
    "start": 22.040000000000003,
    "end": 27.001,
    "text": "解决办法，是六部分高信号包：目标、规则、工具、示例、检索和状态。",
    "segmentId": "artifact-pack",
    "sceneId": "artifact"
  },
  {
    "start": 27.001000000000005,
    "end": 27.847,
    "text": "看注意力预算。",
    "segmentId": "budget-watch",
    "sceneId": "budget"
  },
  {
    "start": 27.847000000000005,
    "end": 30.242,
    "text": "原始历史塞满窗口时，目标会被挤小。",
    "segmentId": "budget-raw",
    "sceneId": "budget"
  },
  {
    "start": 30.242000000000004,
    "end": 33.079,
    "text": "只保留当前约束和有效证据，目标重新变大。",
    "segmentId": "budget-focus",
    "sceneId": "budget"
  },
  {
    "start": 33.07900000000001,
    "end": 35.388,
    "text": "其余信息移到窗口外，需要时再检索。",
    "segmentId": "budget-outside",
    "sceneId": "budget"
  },
  {
    "start": 35.388000000000005,
    "end": 38.272,
    "text": "不是删掉知识，而是让每个字都服务当前动作。",
    "segmentId": "budget-knowledge",
    "sceneId": "budget"
  },
  {
    "start": 38.272000000000006,
    "end": 40.359,
    "text": "让下一步目标始终排在最前面。",
    "segmentId": "budget-priority",
    "sceneId": "budget"
  },
  {
    "start": 40.359,
    "end": 44.988,
    "text": "每一步只让 AI 智能体看见四件事：目标、约束、证据和当前状态。",
    "segmentId": "decision-four",
    "sceneId": "decision"
  },
  {
    "start": 44.98800000000001,
    "end": 49.5,
    "text": "其他信息先留在窗口外，真正需要时再取，判断完成后再更新状态。",
    "segmentId": "decision-rest",
    "sceneId": "decision"
  }
]
