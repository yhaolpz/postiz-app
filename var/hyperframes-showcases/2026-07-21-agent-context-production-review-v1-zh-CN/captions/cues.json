[
  {
    "start": 0.1,
    "end": 2.55,
    "text": "你知道怎么给 AI 智能体高信号上下文吗？",
    "segmentId": "hook-question",
    "sceneId": "hook"
  },
  {
    "start": 2.5500000000000003,
    "end": 5.419,
    "text": "接下来我来告诉你，Anthropic 是怎么解决这个问题的。",
    "segmentId": "promise-method",
    "sceneId": "promise"
  },
  {
    "start": 5.418999999999999,
    "end": 10.792,
    "text": "视频全程干货高价值，让你成为更擅长使用 AI 的人，内容较长，点点关注收藏不迷路。",
    "segmentId": "opening-fixed",
    "sceneId": "promise"
  },
  {
    "start": 10.792,
    "end": 13.083,
    "text": "Anthropic 把上下文看成有限的注意力预算。",
    "segmentId": "authority-budget",
    "sceneId": "authority"
  },
  {
    "start": 13.083,
    "end": 17.633,
    "text": "窗口越满，下一步真正重要的信号越容易变弱，判断也会偏离当前目标。",
    "segmentId": "authority-signal",
    "sceneId": "authority"
  },
  {
    "start": 17.633000000000003,
    "end": 20.415,
    "text": "提示词越长，AI 智能体越可能追着旧细节跑。",
    "segmentId": "artifact-pain",
    "sceneId": "artifact"
  },
  {
    "start": 20.415000000000006,
    "end": 25.286,
    "text": "解决办法，是六部分高信号包：目标、规则、工具、示例、检索和状态。",
    "segmentId": "artifact-pack",
    "sceneId": "artifact"
  },
  {
    "start": 25.28600000000001,
    "end": 26.097,
    "text": "看注意力预算。",
    "segmentId": "budget-watch",
    "sceneId": "budget"
  },
  {
    "start": 26.09700000000001,
    "end": 28.442,
    "text": "原始历史塞满窗口时，目标会被挤小。",
    "segmentId": "budget-raw",
    "sceneId": "budget"
  },
  {
    "start": 28.44200000000001,
    "end": 31.229,
    "text": "只保留当前约束和有效证据，目标重新变大。",
    "segmentId": "budget-focus",
    "sceneId": "budget"
  },
  {
    "start": 31.229000000000013,
    "end": 33.488,
    "text": "其余信息移到窗口外，需要时再检索。",
    "segmentId": "budget-outside",
    "sceneId": "budget"
  },
  {
    "start": 33.488000000000014,
    "end": 36.322,
    "text": "不是删掉知识，而是让每个字都服务当前动作。",
    "segmentId": "budget-knowledge",
    "sceneId": "budget"
  },
  {
    "start": 36.32200000000002,
    "end": 38.319,
    "text": "让下一步目标始终排在最前面。",
    "segmentId": "budget-priority",
    "sceneId": "budget"
  },
  {
    "start": 38.31900000000001,
    "end": 42.868,
    "text": "每一步只让 AI 智能体看见四件事：目标、约束、证据和当前状态。",
    "segmentId": "decision-four",
    "sceneId": "decision"
  },
  {
    "start": 42.868000000000016,
    "end": 47.178,
    "text": "其他信息先留在窗口外，真正需要时再取，判断完成后再更新状态。",
    "segmentId": "decision-rest",
    "sceneId": "decision"
  },
  {
    "start": 47.17800000000001,
    "end": 51.885,
    "text": "长期任务不是让 AI 智能体记住全部历史，而是始终找得到下一步需要的证据。",
    "segmentId": "memory-rule",
    "sceneId": "memory"
  },
  {
    "start": 51.88500000000001,
    "end": 56.999,
    "text": "每完成一步，就压缩旧轨迹并更新当前状态，让有限的注意力预算继续服务目标。",
    "segmentId": "memory-refresh",
    "sceneId": "memory"
  },
  {
    "start": 56.99900000000002,
    "end": 60.1,
    "text": "这才是 AI 智能体长期任务持续推进的关键。",
    "segmentId": "memory-close",
    "sceneId": "memory"
  }
]
