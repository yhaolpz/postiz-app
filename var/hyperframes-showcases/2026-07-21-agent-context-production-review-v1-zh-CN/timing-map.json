  "segments": [
    {
      "id": "hook-question",
      "sceneId": "hook",
      "text": "你知道怎么给 AI 智能体高信号上下文吗？",
      "desiredGapBefore": 0,
      "actualGapBefore": 0,
      "audioStart": 0,
      "audioDuration": 3.072,
      "audibleLocalStart": 0.155,
      "audibleLocalEnd": 2.476,
      "spokenStart": 0.155,
      "spokenEnd": 2.476
    },
    {
      "id": "promise-method",
      "sceneId": "promise",
      "text": "接下来我来告诉你，Anthropic 是怎么解决这个问题的。",
      "desiredGapBefore": 0.12,
      "actualGapBefore": 0.12,
      "audioStart": 2.45,
      "audioDuration": 3.504,
      "audibleLocalStart": 0.146,
      "audibleLocalEnd": 2.916,
      "spokenStart": 2.596,
      "spokenEnd": 5.366
    },
    {
      "id": "opening-fixed",
      "sceneId": "promise",
      "text": "视频全程干货高价值，让你成为更擅长使用 AI 的人，内容较长，点点关注收藏不迷路。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 5.319,
      "audioDuration": 5.928,
      "audibleLocalStart": 0.147,
      "audibleLocalEnd": 5.37,
      "spokenStart": 5.466,
      "spokenEnd": 10.689
    },
    {
      "id": "authority-budget",
      "sceneId": "authority",
      "text": "Anthropic 把上下文看成有限的注意力预算。",
      "desiredGapBefore": 0.16,
      "actualGapBefore": 0.16,
      "audioStart": 10.692,
      "audioDuration": 2.928,
      "audibleLocalStart": 0.157,
      "audibleLocalEnd": 2.335,
      "spokenStart": 10.849,
      "spokenEnd": 13.027
    },
    {
      "id": "authority-signal",
      "sceneId": "authority",
      "text": "窗口越满，下一步真正重要的信号越容易变弱，判断也会偏离当前目标。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 12.983,
      "audioDuration": 5.112,
      "audibleLocalStart": 0.144,
      "audibleLocalEnd": 4.538,
      "spokenStart": 13.127,
      "spokenEnd": 17.521
    },
    {
      "id": "artifact-pain",
      "sceneId": "artifact",
      "text": "提示词越长，AI 智能体越可能追着旧细节跑。",
      "desiredGapBefore": 0.16,
      "actualGapBefore": 0.16,
      "audioStart": 17.533,
      "audioDuration": 3.408,
      "audibleLocalStart": 0.148,
      "audibleLocalEnd": 2.823,
      "spokenStart": 17.681,
      "spokenEnd": 20.356
    },
    {
      "id": "artifact-pack",
      "sceneId": "artifact",
      "text": "解决办法，是六部分高信号包：目标、规则、工具、示例、检索和状态。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 20.315,
      "audioDuration": 5.424,
      "audibleLocalStart": 0.141,
      "audibleLocalEnd": 4.855,
      "spokenStart": 20.456,
      "spokenEnd": 25.17
    },
    {
      "id": "budget-watch",
      "sceneId": "budget",
      "text": "看注意力预算。",
      "desiredGapBefore": 0.16,
      "actualGapBefore": 0.16,
      "audioStart": 25.186,
      "audioDuration": 1.776,
      "audibleLocalStart": 0.144,
      "audibleLocalEnd": 0.862,
      "spokenStart": 25.33,
      "spokenEnd": 26.048
    },
    {
      "id": "budget-raw",
      "sceneId": "budget",
      "text": "原始历史塞满窗口时，目标会被挤小。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 25.997,
      "audioDuration": 2.976,
      "audibleLocalStart": 0.151,
      "audibleLocalEnd": 2.395,
      "spokenStart": 26.148,
      "spokenEnd": 28.392
    },
    {
      "id": "budget-focus",
      "sceneId": "budget",
      "text": "只保留当前约束和有效证据，目标重新变大。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 28.342,
      "audioDuration": 3.408,
      "audibleLocalStart": 0.15,
      "audibleLocalEnd": 2.828,
      "spokenStart": 28.492,
      "spokenEnd": 31.17
    },
    {
      "id": "budget-outside",
      "sceneId": "budget",
      "text": "其余信息移到窗口外，需要时再检索。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 31.129,
      "audioDuration": 2.904,
      "audibleLocalStart": 0.141,
      "audibleLocalEnd": 2.31,
      "spokenStart": 31.27,
      "spokenEnd": 33.439
    },
    {
      "id": "budget-knowledge",
      "sceneId": "budget",
      "text": "不是删掉知识，而是让每个字都服务当前动作。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 33.388,
      "audioDuration": 3.456,
      "audibleLocalStart": 0.151,
      "audibleLocalEnd": 2.88,
      "spokenStart": 33.539,
      "spokenEnd": 36.268
    },
    {
      "id": "budget-priority",
      "sceneId": "budget",
      "text": "让下一步目标始终排在最前面。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 36.222,
      "audioDuration": 2.568,
      "audibleLocalStart": 0.146,
      "audibleLocalEnd": 1.986,
      "spokenStart": 36.368,
      "spokenEnd": 38.208
    },
    {
      "id": "decision-four",
      "sceneId": "decision",
      "text": "每一步只让 AI 智能体看见四件事：目标、约束、证据和当前状态。",
      "desiredGapBefore": 0.16,
      "actualGapBefore": 0.16,
      "audioStart": 38.219,
      "audioDuration": 5.16,
      "audibleLocalStart": 0.149,
      "audibleLocalEnd": 4.593,
      "spokenStart": 38.368,
      "spokenEnd": 42.812
    },
    {
      "id": "decision-rest",
      "sceneId": "decision",
      "text": "其他信息先留在窗口外，真正需要时再取，判断完成后再更新状态。",
      "desiredGapBefore": 0.1,
      "actualGapBefore": 0.1,
      "audioStart": 42.768,
      "audioDuration": 4.872,
      "audibleLocalStart": 0.144,
      "audibleLocalEnd": 4.298,
      "spokenStart": 42.912,
      "spokenEnd": 47.066
    },
    {
      "id": "memory-rule",
      "sceneId": "memory",
      "text": "长期任务不是让 AI 智能体记住全部历史，而是始终找得到下一步需要的证据。",
      "desiredGapBefore": 0.16,
      "actualGapBefore": 0.16,
