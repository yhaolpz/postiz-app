{
  "name": "building-effective-agents-longform-zh-cn",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "node build.mjs --prepare",
    "tts": "node build.mjs --tts",
    "compile": "node build.mjs --compile",
    "check": "pnpm dlx hyperframes@0.7.62 check . --snapshots --frame-check=severity=error",
    "check:balance": "node qa/check-visual-balance.mjs",
    "check:semantics": "node qa/check-semantic-beats.mjs",
    "check:transitions": "node qa/check-transition-continuity.mjs",
    "check:full": "pnpm dlx hyperframes@0.7.62 check . --at-transitions --timeout 30000 --snapshots --frame-check=severity=error",
    "preview": "pnpm dlx hyperframes@0.7.62 preview . --port 3023 --no-open",
    "render": "pnpm dlx hyperframes@0.7.62 render . --quality high --strict --output renders/building-effective-agents-longform.zh-CN.mp4"
  }
}
