  "segments": [
    {
      "id": "c01-p01-u01",
      "sceneId": "c01-p01",
      "chapterIndex": 0,
      "paragraphIndex": 0,
      "utteranceIndex": 0,
      "text": "AI 智能体看到恶意网页，还能直接替你操作吗？",
      "gapBefore": 0,
      "audioDuration": 4.68,
      "audioStart": 0,
      "spokenStart": 0.192,
      "spokenEnd": 3.877,
      "actualGapBefore": 0
    },
    {
      "id": "c01-p02-u01",
      "sceneId": "c01-p02",
      "chapterIndex": 0,
      "paragraphIndex": 1,
      "utteranceIndex": 0,
      "text": "OpenAI 提醒，提示注入正在变得更像社会工程：它不一定大喊“忽略用户”，而是装成一段合情合理的新流程。",
      "gapBefore": 1.2,
      "audioDuration": 9.552,
      "audioStart": 4.894,
      "spokenStart": 5.077,
      "spokenEnd": 13.673,
      "actualGapBefore": 1.2
    },
    {
      "id": "c01-p03-u01",
      "sceneId": "c01-p03",
      "chapterIndex": 0,
      "paragraphIndex": 2,
      "utteranceIndex": 0,
      "text": "想象你让智能体安排家庭生日聚餐，它却差点把住址发给一个假的验证网站。",
      "gapBefore": 0.5,
      "audioDuration": 6.768,
      "audioStart": 13.989,
      "spokenStart": 14.173,
      "spokenEnd": 19.973,
      "actualGapBefore": 0.5
    },
    {
      "id": "c01-p03-u02",
      "sceneId": "c01-p03",
      "chapterIndex": 0,
      "paragraphIndex": 2,
      "utteranceIndex": 1,
      "text": "损失往往发生在你看到结果之前。",
      "gapBefore": 0.25,
      "audioDuration": 3.624,
      "audioStart": 20.042,
      "spokenStart": 20.223,
      "spokenEnd": 22.885,
      "actualGapBefore": 0.25
    },
    {
      "id": "c01-p04-u01",
      "sceneId": "c01-p04",
      "chapterIndex": 0,
      "paragraphIndex": 3,
      "utteranceIndex": 0,
      "text": "看完你会得到一张 AI 智能体三级行动权限矩阵：哪些事自动做，哪些事先确认，哪些事必须阻断。",
      "gapBefore": 0.5,
      "audioDuration": 9.12,
      "audioStart": 23.198,
      "spokenStart": 23.385,
      "spokenEnd": 31.542,
      "actualGapBefore": 0.5
    },
    {
      "id": "c01-p05-u01",
      "sceneId": "c01-p05",
      "chapterIndex": 0,
      "paragraphIndex": 4,
      "utteranceIndex": 0,
      "text": "真正要问的，不只是“智能体能不能识别恶意句子”，而是“如果它被骗了，这句话最多能让它做到哪一步”。",
      "gapBefore": 0.5,
      "audioDuration": 8.616,
      "audioStart": 31.852,
      "spokenStart": 32.042,
      "spokenEnd": 39.683,
      "actualGapBefore": 0.5
    },
    {
      "id": "c01-p06-u01",
      "sceneId": "c01-p06",
      "chapterIndex": 0,
      "paragraphIndex": 5,
      "utteranceIndex": 0,
      "text": "视频全程干货高价值，让你成为更擅长使用 AI 的人，内容较长，点点关注收藏不迷路。",
      "gapBefore": 0.5,
      "audioDuration": 8.064,
      "audioStart": 40.001,
      "spokenStart": 40.183,
      "spokenEnd": 47.269,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p01-u01",
      "sceneId": "c02-p01",
      "chapterIndex": 1,
      "paragraphIndex": 0,
      "utteranceIndex": 0,
      "text": "先从一件人人都懂的小事开始。",
      "gapBefore": 0.8,
      "audioDuration": 3.24,
      "audioStart": 47.888,
      "spokenStart": 48.069,
      "spokenEnd": 50.333,
      "actualGapBefore": 0.8
    },
    {
      "id": "c02-p01-u02",
      "sceneId": "c02-p01",
      "chapterIndex": 1,
      "paragraphIndex": 0,
      "utteranceIndex": 1,
      "text": "你让 AI 智能体找一家适合家庭生日聚餐的餐厅，比较菜单、路程和空位，并帮你订周六晚上的桌位。",
      "gapBefore": 0.25,
      "audioDuration": 9.528,
      "audioStart": 50.389,
      "spokenStart": 50.583,
      "spokenEnd": 59.14,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p02-u01",
      "sceneId": "c02-p02",
      "chapterIndex": 1,
      "paragraphIndex": 1,
      "utteranceIndex": 0,
      "text": "为了完成任务，它会阅读餐厅网页、点评、地图、取消规则，也可能查看亲友发来的邮件。",
      "gapBefore": 0.5,
      "audioDuration": 8.424,
      "audioStart": 59.451,
      "spokenStart": 59.64,
      "spokenEnd": 67.088,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p02-u02",
      "sceneId": "c02-p02",
      "chapterIndex": 1,
      "paragraphIndex": 1,
      "utteranceIndex": 1,
      "text": "大部分内容确实有用，但“有用”不等于“可信”。",
      "gapBefore": 0.25,
      "audioDuration": 4.368,
      "audioStart": 67.143,
      "spokenStart": 67.338,
      "spokenEnd": 70.736,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p03-u01",
      "sceneId": "c02-p03",
      "chapterIndex": 1,
      "paragraphIndex": 2,
      "utteranceIndex": 0,
      "text": "提示注入，就是把新的指令藏进这些外部材料里。",
      "gapBefore": 0.5,
      "audioDuration": 4.8,
      "audioStart": 71.063,
      "spokenStart": 71.236,
      "spokenEnd": 75.076,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p03-u02",
      "sceneId": "c02-p03",
      "chapterIndex": 1,
      "paragraphIndex": 2,
      "utteranceIndex": 1,
      "text": "网页表面在介绍餐厅，里面却可能要求智能体放弃原任务，改走攻击者安排的流程。",
      "gapBefore": 0.25,
      "audioDuration": 7.68,
      "audioStart": 75.134,
      "spokenStart": 75.326,
      "spokenEnd": 82.039,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p04-u01",
      "sceneId": "c02-p04",
      "chapterIndex": 1,
      "paragraphIndex": 3,
      "utteranceIndex": 0,
      "text": "OpenAI 提到一封在 2025 年被外部研究者报告的恶意邮件。",
      "gapBefore": 0.5,
      "audioDuration": 5.664,
      "audioStart": 82.35,
      "spokenStart": 82.539,
      "spokenEnd": 87.234,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p04-u02",
      "sceneId": "c02-p04",
      "chapterIndex": 1,
      "paragraphIndex": 3,
      "utteranceIndex": 1,
      "text": "在一个特定测试任务里，这类社会工程内容有一半机会奏效。",
      "gapBefore": 0.25,
      "audioDuration": 5.448,
      "audioStart": 87.32,
      "spokenStart": 87.484,
      "spokenEnd": 91.984,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p04-u03",
      "sceneId": "c02-p04",
      "chapterIndex": 1,
      "paragraphIndex": 3,
      "utteranceIndex": 2,
      "text": "这不是所有场景的失败率，却足以说明：像真的故事，有时能骗过简单过滤。",
      "gapBefore": 0.25,
      "audioDuration": 7.296,
      "audioStart": 92.045,
      "spokenStart": 92.234,
      "spokenEnd": 98.553,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p05-u01",
      "sceneId": "c02-p05",
      "chapterIndex": 1,
      "paragraphIndex": 4,
      "utteranceIndex": 0,
      "text": "因此，只搜索“忽略之前指令”之类的可疑词远远不够。",
      "gapBefore": 0.5,
      "audioDuration": 5.208,
      "audioStart": 98.868,
      "spokenStart": 99.053,
      "spokenEnd": 103.292,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p05-u02",
      "sceneId": "c02-p05",
      "chapterIndex": 1,
      "paragraphIndex": 4,
      "utteranceIndex": 1,
      "text": "成熟攻击可能看起来像公司政策、同事请求，或者一个贴心的验证步骤。",
      "gapBefore": 0.25,
      "audioDuration": 6.576,
      "audioStart": 103.371,
      "spokenStart": 103.542,
      "spokenEnd": 109.169,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p05-u03",
      "sceneId": "c02-p05",
      "chapterIndex": 1,
      "paragraphIndex": 4,
      "utteranceIndex": 2,
      "text": "判断它是不是谎言，需要过滤器未必拥有的上下文。",
      "gapBefore": 0.25,
      "audioDuration": 5.16,
      "audioStart": 109.245,
      "spokenStart": 109.419,
      "spokenEnd": 113.604,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p06-u01",
      "sceneId": "c02-p06",
      "chapterIndex": 1,
      "paragraphIndex": 5,
      "utteranceIndex": 0,
      "text": "OpenAI 用“来源和出口”解释这类风险。",
      "gapBefore": 0.5,
      "audioDuration": 3.888,
      "audioStart": 113.896,
      "spokenStart": 114.104,
      "spokenEnd": 116.965,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p06-u02",
      "sceneId": "c02-p06",
      "chapterIndex": 1,
      "paragraphIndex": 5,
      "utteranceIndex": 1,
      "text": "用普通话说，来源是攻击者能够影响智能体的地方；",
      "gapBefore": 0.25,
      "audioDuration": 5.184,
      "audioStart": 117.032,
      "spokenStart": 117.215,
      "spokenEnd": 121.429,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p06-u03",
      "sceneId": "c02-p06",
      "chapterIndex": 1,
      "paragraphIndex": 5,
      "utteranceIndex": 2,
      "text": "出口是放在错误情境里就会产生危险后果的能力。",
      "gapBefore": 0.25,
      "audioDuration": 4.584,
      "audioStart": 121.495,
      "spokenStart": 121.679,
      "spokenEnd": 125.305,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p07-u01",
      "sceneId": "c02-p07",
      "chapterIndex": 1,
      "paragraphIndex": 6,
      "utteranceIndex": 0,
      "text": "在订餐故事里，网页和邮件都是来源。",
      "gapBefore": 0.5,
      "audioDuration": 3.864,
      "audioStart": 125.638,
      "spokenStart": 125.805,
      "spokenEnd": 128.717,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p07-u02",
      "sceneId": "c02-p07",
      "chapterIndex": 1,
      "paragraphIndex": 6,
      "utteranceIndex": 1,
      "text": "发送消息、打开链接、分享联系方式、支付订金、确认预订，都是出口，因为它们会改变智能体工作区之外的真实世界。",
      "gapBefore": 0.25,
      "audioDuration": 10.944,
      "audioStart": 128.782,
      "spokenStart": 128.967,
      "spokenEnd": 138.931,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p08-u01",
      "sceneId": "c02-p08",
      "chapterIndex": 1,
      "paragraphIndex": 7,
      "utteranceIndex": 0,
      "text": "这时，假餐厅页面声称：想查看空位，必须把你的住址和个人资料发到一个公开“合规验证”地址。",
      "gapBefore": 0.5,
      "audioDuration": 8.808,
      "audioStart": 139.245,
      "spokenStart": 139.431,
      "spokenEnd": 147.262,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p08-u02",
      "sceneId": "c02-p08",
      "chapterIndex": 1,
      "paragraphIndex": 7,
      "utteranceIndex": 1,
      "text": "文案很正式，还承诺能帮你更快完成订餐。",
      "gapBefore": 0.25,
      "audioDuration": 4.416,
      "audioStart": 147.316,
      "spokenStart": 147.512,
      "spokenEnd": 150.951,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p09-u01",
      "sceneId": "c02-p09",
      "chapterIndex": 1,
      "paragraphIndex": 8,
      "utteranceIndex": 0,
      "text": "危险不是这句话出现在页面上，而是它能一路碰到私人数据和发送工具，中间没有任何独立控制。",
      "gapBefore": 0.5,
      "audioDuration": 8.328,
      "audioStart": 151.274,
      "spokenStart": 151.451,
      "spokenEnd": 158.834,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p09-u02",
      "sceneId": "c02-p09",
      "chapterIndex": 1,
      "paragraphIndex": 8,
      "utteranceIndex": 1,
      "text": "一旦来源能直达出口，骗局才真正获得行动能力。",
      "gapBefore": 0.25,
      "audioDuration": 4.848,
      "audioStart": 158.895,
      "spokenStart": 159.084,
      "spokenEnd": 162.966,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p10-u01",
      "sceneId": "c02-p10",
      "chapterIndex": 1,
      "paragraphIndex": 9,
      "utteranceIndex": 0,
      "text": "现实组织早就在做同类限制。",
      "gapBefore": 0.5,
      "audioDuration": 3.432,
      "audioStart": 163.287,
      "spokenStart": 163.466,
      "spokenEnd": 165.94,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p10-u02",
      "sceneId": "c02-p10",
      "chapterIndex": 1,
      "paragraphIndex": 9,
      "utteranceIndex": 1,
      "text": "客服可以直接处理小额退款，金额变大就要第二个人批准。",
      "gapBefore": 0.25,
      "audioDuration": 5.496,
      "audioStart": 166.008,
      "spokenStart": 166.19,
      "spokenEnd": 170.725,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p10-u03",
      "sceneId": "c02-p10",
      "chapterIndex": 1,
      "paragraphIndex": 9,
      "utteranceIndex": 2,
      "text": "钓鱼邮件过滤仍然需要，但即使漏过一封，退款上限也能限制损失。",
      "gapBefore": 0.25,
      "audioDuration": 6.48,
      "audioStart": 170.789,
      "spokenStart": 170.975,
      "spokenEnd": 176.485,
      "actualGapBefore": 0.25
    },
    {
      "id": "c02-p11-u01",
      "sceneId": "c02-p11",
      "chapterIndex": 1,
      "paragraphIndex": 10,
      "utteranceIndex": 0,
      "text": "所以第一条原则是：安全不能建立在“永远识别成功”上，而要切断不可信信息直达高后果能力的路径。",
      "gapBefore": 0.5,
      "audioDuration": 9.024,
      "audioStart": 176.804,
      "spokenStart": 176.985,
      "spokenEnd": 185.044,
      "actualGapBefore": 0.5
    },
    {
      "id": "c02-p11-u02",
      "sceneId": "c02-p11",
      "chapterIndex": 1,
      "paragraphIndex": 10,
      "utteranceIndex": 1,
      "text": "接下来更难的问题是，哪些行动可以继续，哪些必须停下来？",
      "gapBefore": 0.25,
      "audioDuration": 5.688,
      "audioStart": 185.117,
      "spokenStart": 185.294,
      "spokenEnd": 190.035,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p01-u01",
      "sceneId": "c03-p01",
      "chapterIndex": 2,
      "paragraphIndex": 0,
      "utteranceIndex": 0,
      "text": "回到生日聚餐。",
      "gapBefore": 0.8,
      "audioDuration": 2.016,
      "audioStart": 190.636,
      "spokenStart": 190.835,
      "spokenEnd": 191.878,
      "actualGapBefore": 0.8
    },
    {
      "id": "c03-p01-u02",
      "sceneId": "c03-p01",
      "chapterIndex": 2,
      "paragraphIndex": 0,
      "utteranceIndex": 1,
      "text": "智能体可以查公开菜单、比较路程、整理候选，也可以发送住址、确认桌位、支付订金、披露个人资料。",
      "gapBefore": 0.25,
      "audioDuration": 9.648,
      "audioStart": 191.942,
      "spokenStart": 192.128,
      "spokenEnd": 200.793,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p01-u03",
      "sceneId": "c03-p01",
      "chapterIndex": 2,
      "paragraphIndex": 0,
      "utteranceIndex": 2,
      "text": "这些动作显然不该共用同一种权限。",
      "gapBefore": 0.25,
      "audioDuration": 4.08,
      "audioStart": 200.856,
      "spokenStart": 201.043,
      "spokenEnd": 204.155,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p02-u01",
      "sceneId": "c03-p02",
      "chapterIndex": 2,
      "paragraphIndex": 1,
      "utteranceIndex": 0,
      "text": "每次给工具权限前，先问五个问题：它会不会产生外部变化？",
      "gapBefore": 0.5,
      "audioDuration": 5.832,
      "audioStart": 204.464,
      "spokenStart": 204.655,
      "spokenEnd": 209.52,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p02-u02",
      "sceneId": "c03-p02",
      "chapterIndex": 2,
      "paragraphIndex": 1,
      "utteranceIndex": 1,
      "text": "会不会接触敏感数据？",
      "gapBefore": 0.25,
      "audioDuration": 2.544,
      "audioStart": 209.561,
      "spokenStart": 209.77,
      "spokenEnd": 211.314,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p02-u03",
      "sceneId": "c03-p02",
      "chapterIndex": 2,
      "paragraphIndex": 1,
      "utteranceIndex": 2,
      "text": "目标地址是不是新的？",
      "gapBefore": 0.25,
      "audioDuration": 2.4,
      "audioStart": 211.381,
      "spokenStart": 211.564,
      "spokenEnd": 213.003,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p02-u04",
      "sceneId": "c03-p02",
      "chapterIndex": 2,
      "paragraphIndex": 1,
      "utteranceIndex": 3,
      "text": "结果能不能撤销？",
      "gapBefore": 0.25,
      "audioDuration": 2.208,
      "audioStart": 213.077,
      "spokenStart": 213.253,
      "spokenEnd": 214.502,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p02-u05",
      "sceneId": "c03-p02",
      "chapterIndex": 2,
      "paragraphIndex": 1,
      "utteranceIndex": 4,
      "text": "它是否明确服务于用户原本的目标？",
      "gapBefore": 0.25,
      "audioDuration": 3.768,
      "audioStart": 214.566,
      "spokenStart": 214.752,
      "spokenEnd": 217.563,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p03-u01",
      "sceneId": "c03-p03",
      "chapterIndex": 2,
      "paragraphIndex": 2,
      "utteranceIndex": 0,
      "text": "第一档叫“自动执行”。",
      "gapBefore": 0.5,
      "audioDuration": 2.304,
      "audioStart": 217.878,
      "spokenStart": 218.063,
      "spokenEnd": 219.405,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p03-u02",
      "sceneId": "c03-p03",
      "chapterIndex": 2,
      "paragraphIndex": 2,
      "utteranceIndex": 1,
      "text": "读取公开信息、整理比较、计算路程、在本地写候选，都可以自动完成，前提是后果很低、能够撤销、没有超出任务范围，也不向外发送敏感信息。",
      "gapBefore": 0.25,
      "audioDuration": 13.44,
      "audioStart": 219.46,
      "spokenStart": 219.655,
      "spokenEnd": 232.122,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p04-u01",
      "sceneId": "c03-p04",
      "chapterIndex": 2,
      "paragraphIndex": 3,
      "utteranceIndex": 0,
      "text": "自动执行不等于无限权限。",
      "gapBefore": 0.5,
      "audioDuration": 3.144,
      "audioStart": 232.451,
      "spokenStart": 232.622,
      "spokenEnd": 234.819,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p04-u02",
      "sceneId": "c03-p04",
      "chapterIndex": 2,
      "paragraphIndex": 3,
      "utteranceIndex": 1,
      "text": "搜索范围仍要有边界，只开放必要的读取能力，草稿先留在本地，临时文件及时清理。",
      "gapBefore": 0.25,
      "audioDuration": 7.824,
      "audioStart": 234.893,
      "spokenStart": 235.069,
      "spokenEnd": 241.93,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p04-u03",
      "sceneId": "c03-p04",
      "chapterIndex": 2,
      "paragraphIndex": 3,
      "utteranceIndex": 2,
      "text": "这样能减少无谓打断，又不给外部文字直达高风险工具的机会。",
      "gapBefore": 0.25,
      "audioDuration": 6.192,
      "audioStart": 241.994,
      "spokenStart": 242.18,
      "spokenEnd": 247.393,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p05-u01",
      "sceneId": "c03-p05",
      "chapterIndex": 2,
      "paragraphIndex": 4,
      "utteranceIndex": 0,
      "text": "第二档叫“确认后执行”。",
      "gapBefore": 0.5,
      "audioDuration": 2.616,
      "audioStart": 247.71,
      "spokenStart": 247.893,
      "spokenEnd": 249.542,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p05-u02",
      "sceneId": "c03-p05",
      "chapterIndex": 2,
      "paragraphIndex": 4,
      "utteranceIndex": 1,
      "text": "只要动作会改变外部系统、产生费用、发送身份信息、触达新的接收方，或者形成用户必须承担的承诺，就应该先获得清楚、具体的同意。",
      "gapBefore": 0.25,
      "audioDuration": 12.144,
      "audioStart": 249.605,
      "spokenStart": 249.792,
      "spokenEnd": 260.963,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p06-u01",
      "sceneId": "c03-p06",
      "chapterIndex": 2,
      "paragraphIndex": 5,
      "utteranceIndex": 0,
      "text": "订餐时，可以在发送必要电话、确认具体时间、接受取消规则或支付订金之前询问用户。",
      "gapBefore": 0.5,
      "audioDuration": 8.736,
      "audioStart": 261.275,
      "spokenStart": 261.463,
      "spokenEnd": 269.225,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p06-u02",
      "sceneId": "c03-p06",
      "chapterIndex": 2,
      "paragraphIndex": 5,
      "utteranceIndex": 1,
      "text": "目的确实合理，但餐厅、金额、数据和责任都已经进入真实世界。",
      "gapBefore": 0.25,
      "audioDuration": 6.408,
      "audioStart": 269.295,
      "spokenStart": 269.475,
      "spokenEnd": 274.917,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p07-u01",
      "sceneId": "c03-p07",
      "chapterIndex": 2,
      "paragraphIndex": 6,
      "utteranceIndex": 0,
      "text": "OpenAI 介绍过一种敏感传输保护：把即将发送的信息展示给用户，请用户确认；",
      "gapBefore": 0.5,
      "audioDuration": 7.08,
      "audioStart": 275.232,
      "spokenStart": 275.417,
      "spokenEnd": 281.502,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p07-u02",
      "sceneId": "c03-p07",
      "chapterIndex": 2,
      "paragraphIndex": 6,
      "utteranceIndex": 1,
      "text": "或者直接阻断，再让智能体寻找其它路径。",
      "gapBefore": 0.25,
      "audioDuration": 4.488,
      "audioStart": 281.556,
      "spokenStart": 281.752,
      "spokenEnd": 285.245,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p07-u03",
      "sceneId": "c03-p07",
      "chapterIndex": 2,
      "paragraphIndex": 6,
      "utteranceIndex": 2,
      "text": "重点是让人看见真实内容和真实目的地。",
      "gapBefore": 0.25,
      "audioDuration": 4.368,
      "audioStart": 285.308,
      "spokenStart": 285.495,
      "spokenEnd": 288.894,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p08-u01",
      "sceneId": "c03-p08",
      "chapterIndex": 2,
      "paragraphIndex": 7,
      "utteranceIndex": 0,
      "text": "一个只有“允许吗”的按钮，不算高质量同意。",
      "gapBefore": 0.5,
      "audioDuration": 4.008,
      "audioStart": 289.209,
      "spokenStart": 289.394,
      "spokenEnd": 292.427,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p08-u02",
      "sceneId": "c03-p08",
      "chapterIndex": 2,
      "paragraphIndex": 7,
      "utteranceIndex": 1,
      "text": "确认页应该说清楚：什么数据会离开系统、发到哪里、为什么需要、会改变什么，以及有没有更安全的替代方案。",
      "gapBefore": 0.25,
      "audioDuration": 9.648,
      "audioStart": 292.502,
      "spokenStart": 292.677,
      "spokenEnd": 301.35,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p09-u01",
      "sceneId": "c03-p09",
      "chapterIndex": 2,
      "paragraphIndex": 8,
      "utteranceIndex": 0,
      "text": "第三档叫“阻断或升级”。",
      "gapBefore": 0.5,
      "audioDuration": 2.76,
      "audioStart": 301.664,
      "spokenStart": 301.85,
      "spokenEnd": 303.65,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p09-u02",
      "sceneId": "c03-p09",
      "chapterIndex": 2,
      "paragraphIndex": 8,
      "utteranceIndex": 1,
      "text": "如果动作背离用户目标、没有正当需要、要把秘密发给无关地址、无法把后果控制在可撤销范围，或者风险大到普通确认也不够，就必须停止。",
      "gapBefore": 0.25,
      "audioDuration": 12.456,
      "audioStart": 303.712,
      "spokenStart": 303.9,
      "spokenEnd": 315.375,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p10-u01",
      "sceneId": "c03-p10",
      "chapterIndex": 2,
      "paragraphIndex": 9,
      "utteranceIndex": 0,
      "text": "故事里的搜索和整理可以自动做；",
      "gapBefore": 0.5,
      "audioDuration": 3.48,
      "audioStart": 315.689,
      "spokenStart": 315.875,
      "spokenEnd": 318.373,
      "actualGapBefore": 0.5
    },
    {
      "id": "c03-p10-u02",
      "sceneId": "c03-p10",
      "chapterIndex": 2,
      "paragraphIndex": 9,
      "utteranceIndex": 1,
      "text": "向选定餐厅发送最少联系方式、确认订桌，需要用户批准；",
      "gapBefore": 0.25,
      "audioDuration": 5.952,
      "audioStart": 318.432,
      "spokenStart": 318.623,
      "spokenEnd": 323.577,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p10-u03",
      "sceneId": "c03-p10",
      "chapterIndex": 2,
      "paragraphIndex": 9,
      "utteranceIndex": 2,
      "text": "把住址和隐藏资料发到无关公开地址，直接阻断。",
      "gapBefore": 0.25,
      "audioDuration": 4.968,
      "audioStart": 323.634,
      "spokenStart": 323.827,
      "spokenEnd": 327.805,
      "actualGapBefore": 0.25
    },
    {
      "id": "c03-p10-u04",
      "sceneId": "c03-p10",
      "chapterIndex": 2,
      "paragraphIndex": 9,
      "utteranceIndex": 3,
      "text": "分级已经清楚，下一步是让系统真正执行这些规则。",
      "gapBefore": 0.25,
      "audioDuration": 4.968,
      "audioStart": 327.879,
      "spokenStart": 328.055,
      "spokenEnd": 332.079,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p01-u01",
      "sceneId": "c04-p01",
      "chapterIndex": 3,
      "paragraphIndex": 0,
      "utteranceIndex": 0,
      "text": "权限矩阵要按“能力”设计，而不是按提示词措辞设计。",
      "gapBefore": 0.8,
      "audioDuration": 5.376,
      "audioStart": 332.702,
      "spokenStart": 332.879,
      "spokenEnd": 337.283,
      "actualGapBefore": 0.8
    },
    {
      "id": "c04-p01-u02",
      "sceneId": "c04-p01",
      "chapterIndex": 3,
      "paragraphIndex": 0,
      "utteranceIndex": 1,
      "text": "逐一列出智能体能做的动作、会接触的数据、能够到达的目标、产生的外部后果，以及对应的自动、确认或阻断策略。",
      "gapBefore": 0.25,
      "audioDuration": 10.104,
      "audioStart": 337.338,
      "spokenStart": 337.533,
      "spokenEnd": 346.68,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p02-u01",
      "sceneId": "c04-p02",
      "chapterIndex": 3,
      "paragraphIndex": 1,
      "utteranceIndex": 0,
      "text": "首先拆开“读取”和“发送”。",
      "gapBefore": 0.5,
      "audioDuration": 2.616,
      "audioStart": 346.996,
      "spokenStart": 347.18,
      "spokenEnd": 348.843,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p02-u02",
      "sceneId": "c04-p02",
      "chapterIndex": 3,
      "paragraphIndex": 1,
      "utteranceIndex": 1,
      "text": "能查看日历的工具，不该天然拥有邀请别人开会的能力；",
      "gapBefore": 0.25,
      "audioDuration": 5.256,
      "audioStart": 348.909,
      "spokenStart": 349.093,
      "spokenEnd": 353.386,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p02-u03",
      "sceneId": "c04-p02",
      "chapterIndex": 3,
      "paragraphIndex": 1,
      "utteranceIndex": 2,
      "text": "能写邮件草稿，不该自动发出；",
      "gapBefore": 0.25,
      "audioDuration": 3.432,
      "audioStart": 353.45,
      "spokenStart": 353.636,
      "spokenEnd": 356.094,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p02-u04",
      "sceneId": "c04-p02",
      "chapterIndex": 3,
      "paragraphIndex": 1,
      "utteranceIndex": 3,
      "text": "能浏览网页，也不该顺手上传本地文件。",
      "gapBefore": 0.25,
      "audioDuration": 4.08,
      "audioStart": 356.16,
      "spokenStart": 356.344,
      "spokenEnd": 359.466,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p03-u01",
      "sceneId": "c04-p03",
      "chapterIndex": 3,
      "paragraphIndex": 2,
      "utteranceIndex": 0,
      "text": "在模型做判断之前先保护数据。",
      "gapBefore": 0.5,
      "audioDuration": 3.528,
      "audioStart": 359.802,
      "spokenStart": 359.966,
      "spokenEnd": 362.54,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p03-u02",
      "sceneId": "c04-p03",
      "chapterIndex": 3,
      "paragraphIndex": 2,
      "utteranceIndex": 1,
      "text": "隐藏任务用不到的密钥，只提供最少字段，重要目标使用允许列表，不可信应用放进能识别异常通信的沙箱。",
      "gapBefore": 0.25,
      "audioDuration": 9.696,
      "audioStart": 362.601,
      "spokenStart": 362.79,
      "spokenEnd": 371.498,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p03-u03",
      "sceneId": "c04-p03",
      "chapterIndex": 3,
      "paragraphIndex": 2,
      "utteranceIndex": 2,
      "text": "模型看不到的秘密，就不会被一句网页文案带走。",
      "gapBefore": 0.25,
      "audioDuration": 4.512,
      "audioStart": 371.563,
      "spokenStart": 371.748,
      "spokenEnd": 375.291,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p04-u01",
      "sceneId": "c04-p04",
      "chapterIndex": 3,
      "paragraphIndex": 3,
      "utteranceIndex": 0,
      "text": "再用确定性控制限制后果：金额上限、退款上限、最小 OAuth 范围、一次性凭据、执行前预演、可撤销暂存、速率限制，以及超过阈值后的第二次批准。",
      "gapBefore": 0.5,
      "audioDuration": 13.872,
      "audioStart": 375.616,
      "spokenStart": 375.791,
      "spokenEnd": 388.701,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p05-u01",
      "sceneId": "c04-p05",
      "chapterIndex": 3,
      "paragraphIndex": 4,
      "utteranceIndex": 0,
      "text": "把确认页设计成真正的决策界面。",
      "gapBefore": 0.5,
      "audioDuration": 3.6,
      "audioStart": 389.015,
      "spokenStart": 389.201,
      "spokenEnd": 391.828,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p05-u02",
      "sceneId": "c04-p05",
      "chapterIndex": 3,
      "paragraphIndex": 4,
      "utteranceIndex": 1,
      "text": "展示餐厅、时间、订金、取消规则、联系方式和接收地址；",
      "gapBefore": 0.25,
      "audioDuration": 6.504,
      "audioStart": 391.891,
      "spokenStart": 392.078,
      "spokenEnd": 397.623,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p05-u03",
      "sceneId": "c04-p05",
      "chapterIndex": 3,
      "paragraphIndex": 4,
      "utteranceIndex": 2,
      "text": "高风险变化用普通话说明。",
      "gapBefore": 0.25,
      "audioDuration": 3.288,
      "audioStart": 397.689,
      "spokenStart": 397.873,
      "spokenEnd": 400.2,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p05-u04",
      "sceneId": "c04-p05",
      "chapterIndex": 3,
      "paragraphIndex": 4,
      "utteranceIndex": 3,
      "text": "用户应该能修改内容、缩小范围，或者取消这一动作而保留其它成果。",
      "gapBefore": 0.25,
      "audioDuration": 6.696,
      "audioStart": 400.266,
      "spokenStart": 400.45,
      "spokenEnd": 406.187,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p06-u01",
      "sceneId": "c04-p06",
      "chapterIndex": 3,
      "paragraphIndex": 5,
      "utteranceIndex": 0,
      "text": "阻断条件也要提前写好。",
      "gapBefore": 0.5,
      "audioDuration": 2.952,
      "audioStart": 406.51,
      "spokenStart": 406.687,
      "spokenEnd": 408.666,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p06-u02",
      "sceneId": "c04-p06",
      "chapterIndex": 3,
      "paragraphIndex": 5,
      "utteranceIndex": 1,
      "text": "秘密外传、没有任务需要的新公开地址、无法恢复的破坏动作，以及明显违背用户指令的高后果行为，都应立即停止，并解释触发了哪条边界。",
      "gapBefore": 0.25,
      "audioDuration": 12.456,
      "audioStart": 408.72,
      "spokenStart": 408.916,
      "spokenEnd": 420.39,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p07-u01",
      "sceneId": "c04-p07",
      "chapterIndex": 3,
      "paragraphIndex": 6,
      "utteranceIndex": 0,
      "text": "只记录最终成功还不够，还要记录完整路径：哪段外部内容影响了判断，请求了哪个工具，选择了什么数据，哪条控制允许或拒绝，以及用户具体确认了什么。",
      "gapBefore": 0.5,
      "audioDuration": 13.584,
      "audioStart": 420.704,
      "spokenStart": 420.89,
      "spokenEnd": 433.501,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p08-u01",
      "sceneId": "c04-p08",
      "chapterIndex": 3,
      "paragraphIndex": 7,
      "utteranceIndex": 0,
      "text": "测试时准备三类材料：正常、含糊和明确恶意。",
      "gapBefore": 0.5,
      "audioDuration": 4.968,
      "audioStart": 433.828,
      "spokenStart": 434.001,
      "spokenEnd": 438.012,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p08-u02",
      "sceneId": "c04-p08",
      "chapterIndex": 3,
      "paragraphIndex": 7,
      "utteranceIndex": 1,
      "text": "既检查真实环境最后发生了什么，也检查智能体尝试过什么。",
      "gapBefore": 0.25,
      "audioDuration": 5.856,
      "audioStart": 438.085,
      "spokenStart": 438.262,
      "spokenEnd": 443.153,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p08-u03",
      "sceneId": "c04-p08",
      "chapterIndex": 3,
      "paragraphIndex": 7,
      "utteranceIndex": 2,
      "text": "结果看起来安全，不代表过程中没有碰过被禁止的发送动作。",
      "gapBefore": 0.25,
      "audioDuration": 5.712,
      "audioStart": 443.226,
      "spokenStart": 443.403,
      "spokenEnd": 448.146,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p09-u01",
      "sceneId": "c04-p09",
      "chapterIndex": 3,
      "paragraphIndex": 8,
      "utteranceIndex": 0,
      "text": "可以沿用 OpenAI 的类比：如果这是一名谨慎的客服，哪些事能独立完成，哪些事要主管复核，哪些事无论如何都不该做？",
      "gapBefore": 0.5,
      "audioDuration": 10.296,
      "audioStart": 448.455,
      "spokenStart": 448.646,
      "spokenEnd": 457.959,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p09-u02",
      "sceneId": "c04-p09",
      "chapterIndex": 3,
      "paragraphIndex": 8,
      "utteranceIndex": 1,
      "text": "再把答案翻译成工具、范围、上限和确认规则。",
      "gapBefore": 0.25,
      "audioDuration": 5.136,
      "audioStart": 458.034,
      "spokenStart": 458.209,
      "spokenEnd": 462.375,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p10-u01",
      "sceneId": "c04-p10",
      "chapterIndex": 3,
      "paragraphIndex": 9,
      "utteranceIndex": 0,
      "text": "这张可复用矩阵只有五列：动作或工具、接触的数据、目标地址、外部后果与可撤销性、响应等级。",
      "gapBefore": 0.5,
      "audioDuration": 9.672,
      "audioStart": 462.688,
      "spokenStart": 462.875,
      "spokenEnd": 471.582,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p10-u02",
      "sceneId": "c04-p10",
      "chapterIndex": 3,
      "paragraphIndex": 9,
      "utteranceIndex": 1,
      "text": "每接入一个新工具先填一遍，工具能力变化时再更新。",
      "gapBefore": 0.25,
      "audioDuration": 5.448,
      "audioStart": 471.642,
      "spokenStart": 471.832,
      "spokenEnd": 476.301,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p11-u01",
      "sceneId": "c04-p11",
      "chapterIndex": 3,
      "paragraphIndex": 10,
      "utteranceIndex": 0,
      "text": "现在重新完成生日聚餐。",
      "gapBefore": 0.5,
      "audioDuration": 2.784,
      "audioStart": 476.618,
      "spokenStart": 476.801,
      "spokenEnd": 478.618,
      "actualGapBefore": 0.5
    },
    {
      "id": "c04-p11-u02",
      "sceneId": "c04-p11",
      "chapterIndex": 3,
      "paragraphIndex": 10,
      "utteranceIndex": 1,
      "text": "智能体自动调研并整理候选；",
      "gapBefore": 0.25,
      "audioDuration": 3.408,
      "audioStart": 478.679,
      "spokenStart": 478.868,
      "spokenEnd": 481.292,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p11-u03",
      "sceneId": "c04-p11",
      "chapterIndex": 3,
      "paragraphIndex": 10,
      "utteranceIndex": 2,
      "text": "订桌和发送最少联系方式前请求确认；",
      "gapBefore": 0.25,
      "audioDuration": 4.128,
      "audioStart": 481.354,
      "spokenStart": 481.542,
      "spokenEnd": 484.696,
      "actualGapBefore": 0.25
    },
    {
      "id": "c04-p11-u04",
      "sceneId": "c04-p11",
      "chapterIndex": 3,
      "paragraphIndex": 10,
      "utteranceIndex": 3,
      "text": "假验证地址被阻断，原因清楚显示，然后智能体换一条安全路径继续完成任务。",
      "gapBefore": 0.25,
      "audioDuration": 7.368,
      "audioStart": 484.781,
      "spokenStart": 484.946,
      "spokenEnd": 491.359,
      "actualGapBefore": 0.25
    },
    {
      "id": "c05-p01-u01",
      "sceneId": "c05-p01",
      "chapterIndex": 4,
      "paragraphIndex": 0,
      "utteranceIndex": 0,
      "text": "恶意句子只是来源。",
      "gapBefore": 0.8,
      "audioDuration": 2.304,
      "audioStart": 491.963,
      "spokenStart": 492.159,
      "spokenEnd": 493.476,
      "actualGapBefore": 0.8
    },
    {
      "id": "c05-p01-u02",
      "sceneId": "c05-p01",
      "chapterIndex": 4,
      "paragraphIndex": 0,
      "utteranceIndex": 1,
      "text": "真正的风险，是它能够碰到私人数据和高后果出口。",
      "gapBefore": 0.25,
      "audioDuration": 5.16,
      "audioStart": 493.525,
      "spokenStart": 493.726,
      "spokenEnd": 497.898,
      "actualGapBefore": 0.25
    },
    {
      "id": "c05-p01-u03",
      "sceneId": "c05-p01",
      "chapterIndex": 4,
      "paragraphIndex": 0,
      "utteranceIndex": 2,
      "text": "可靠系统会假设偶尔有人被骗，然后限制被骗之后最多能发生什么。",
      "gapBefore": 0.25,
      "audioDuration": 6.528,
      "audioStart": 497.959,
      "spokenStart": 498.148,
      "spokenEnd": 503.697,
      "actualGapBefore": 0.25
    },
    {
      "id": "c05-p02-u01",
      "sceneId": "c05-p02",
      "chapterIndex": 4,
      "paragraphIndex": 1,
      "utteranceIndex": 0,
      "text": "低后果、可撤销、符合用户目标、没有敏感外传的工作，放进“自动执行”。",
      "gapBefore": 0.5,
      "audioDuration": 6.96,
      "audioStart": 504.014,
      "spokenStart": 504.197,
      "spokenEnd": 510.193,
      "actualGapBefore": 0.5
    },
    {
      "id": "c05-p02-u02",
      "sceneId": "c05-p02",
      "chapterIndex": 4,
      "paragraphIndex": 1,
      "utteranceIndex": 1,
      "text": "即使不打断用户，权限范围也必须足够窄。",
      "gapBefore": 0.25,
      "audioDuration": 4.584,
      "audioStart": 510.263,
      "spokenStart": 510.443,
      "spokenEnd": 514.081,
      "actualGapBefore": 0.25
    },
    {
      "id": "c05-p03-u01",
      "sceneId": "c05-p03",
      "chapterIndex": 4,
      "paragraphIndex": 2,
      "utteranceIndex": 0,
      "text": "真实外部变化、付费、承诺、新接收方或敏感传输，放进“确认后执行”。",
      "gapBefore": 0.5,
      "audioDuration": 7.392,
      "audioStart": 514.392,
      "spokenStart": 514.581,
      "spokenEnd": 520.992,
      "actualGapBefore": 0.5
    },
    {
      "id": "c05-p03-u02",
      "sceneId": "c05-p03",
      "chapterIndex": 4,
      "paragraphIndex": 2,
      "utteranceIndex": 1,
      "text": "展示具体数据、具体地址、目的、后果和更安全的替代方案。",
      "gapBefore": 0.25,
      "audioDuration": 6,
      "audioStart": 521.055,
      "spokenStart": 521.242,
      "spokenEnd": 526.258,
      "actualGapBefore": 0.25
    },
    {
      "id": "c05-p04-u01",
      "sceneId": "c05-p04",
      "chapterIndex": 4,
      "paragraphIndex": 3,
      "utteranceIndex": 0,
      "text": "背离目标、没有正当需要、向无关地址泄露秘密，或产生超出授权边界的不可逆伤害，放进“阻断”。",
      "gapBefore": 0.5,
      "audioDuration": 8.688,
      "audioStart": 526.572,
      "spokenStart": 526.758,
      "spokenEnd": 534.476,
      "actualGapBefore": 0.5
    },
    {
      "id": "c05-p04-u02",
      "sceneId": "c05-p04",
      "chapterIndex": 4,
      "paragraphIndex": 3,
      "utteranceIndex": 1,
      "text": "把边界做进工具和系统，不要只寄希望于模型临场聪明。",
      "gapBefore": 0.25,
      "audioDuration": 5.352,
      "audioStart": 534.53,
      "spokenStart": 534.726,
      "spokenEnd": 539.097,
      "actualGapBefore": 0.25
    },
    {
      "id": "c05-p05-u01",
      "sceneId": "c05-p05",
      "chapterIndex": 4,
      "paragraphIndex": 4,
      "utteranceIndex": 0,
      "text": "关注 Tiny Agent，成为更擅长使用 AI 的人！",
      "gapBefore": 0.5,
      "audioDuration": 4.056,
      "audioStart": 539.404,
      "spokenStart": 539.597,
      "spokenEnd": 542.663,
      "actualGapBefore": 0.5
    }
