POSTIZ_URL=http://localhost:3000
POSTIZ_API_KEY=
POSTIZ_YOUTUBE_INTEGRATION_ID=
POSTIZ_TIKTOK_INTEGRATION_ID=

# Optional. Falls back to the first local organization and connected channels
# when DATABASE_URL is present.
DATABASE_URL=

# Content generation. If OPENAI_API_KEY is absent, the script uses a deterministic
# evergreen fallback for the selected topic.
OPENAI_API_KEY=
AI_VIDEO_LLM_MODEL=gpt-4.1

# TTS providers: say, edge-tts, openai.
# edge-tts uses `uvx edge-tts` by default and is the preferred prototype voice
# for the Agent Sketchbook style.
AI_VIDEO_TTS_PROVIDER=edge-tts
AI_VIDEO_TTS_VOICE=en-US-BrianNeural
AI_VIDEO_TTS_RATE=+8%
AI_VIDEO_EDGE_TTS_COMMAND=uvx
AI_VIDEO_OPENAI_TTS_MODEL=tts-1
AI_VIDEO_OPENAI_TTS_VOICE=alloy

# Current local Postiz setup usually does not have FRONTEND_URL running on 4200.
# serve streams the generated MP4 from this process until publish finishes.
AI_VIDEO_MEDIA_MODE=serve
AI_VIDEO_VISIBILITY=private
AI_VIDEO_PLATFORM=both
AI_VIDEO_TIKTOK_METHOD=DIRECT_POST

# Local Postiz/Temporal helpers. Keep these false for normal local publishing.
AI_VIDEO_SKIP_TOKEN_REFRESH=false
AI_VIDEO_SKIP_TEMPORAL_INIT=false
AI_VIDEO_SKIP_WORKFLOW_KICK=false
