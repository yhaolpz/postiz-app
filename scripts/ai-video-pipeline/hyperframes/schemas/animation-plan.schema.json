{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://indieseek.co/schemas/tiny-agent-animation-plan.v1.json",
  "title": "Tiny Agent Animation Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "duration", "audio", "scenes"],
  "properties": {
    "version": { "const": 1 },
    "duration": { "type": "number", "exclusiveMinimum": 0 },
    "audio": { "type": "string", "minLength": 1 },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "point": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }],
      "items": false
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "start", "end", "template", "title", "caption", "actors", "actions"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "exclusiveMinimum": 0 },
        "template": { "enum": ["augment", "retrieve", "tools", "memory"] },
        "title": { "type": "string", "minLength": 1 },
        "caption": { "type": "string", "minLength": 1 },
        "actors": {
          "type": "object",
          "additionalProperties": false,
          "required": ["human", "agent"],
          "properties": {
            "human": { "type": "string", "minLength": 1 },
            "agent": { "type": "string", "minLength": 1 }
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/poseAction" },
              { "$ref": "#/$defs/flyAction" },
              { "$ref": "#/$defs/plugAction" },
              { "$ref": "#/$defs/storeAction" }
            ]
          }
        }
      }
    },
    "actionBase": {
      "type": "object",
      "required": ["id", "type", "at", "duration"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "type": { "type": "string" },
        "at": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "poseAction": {
      "allOf": [
        { "$ref": "#/$defs/actionBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "at", "duration", "actor", "from", "to"],
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "pose" },
            "at": { "type": "number", "minimum": 0 },
            "duration": { "type": "number", "exclusiveMinimum": 0 },
            "actor": { "enum": ["human", "agent"] },
            "from": { "type": "string", "minLength": 1 },
            "to": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "flyAction": {
      "allOf": [
        { "$ref": "#/$defs/actionBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "at", "duration", "label", "from", "via", "to"],
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "fly" },
            "at": { "type": "number", "minimum": 0 },
            "duration": { "type": "number", "exclusiveMinimum": 0 },
            "label": { "type": "string", "minLength": 1 },
            "from": { "$ref": "#/$defs/point" },
            "via": { "$ref": "#/$defs/point" },
            "to": { "$ref": "#/$defs/point" },
            "accent": { "enum": ["blue", "red", "ink"] }
          }
        }
      ]
    },
    "plugAction": {
      "allOf": [
        { "$ref": "#/$defs/actionBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "at", "duration", "label", "from", "to"],
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "plug" },
            "at": { "type": "number", "minimum": 0 },
            "duration": { "type": "number", "exclusiveMinimum": 0 },
            "label": { "type": "string", "minLength": 1 },
            "from": { "$ref": "#/$defs/point" },
            "to": { "$ref": "#/$defs/point" },
            "result": { "type": "string" }
          }
        }
      ]
    },
    "storeAction": {
      "allOf": [
        { "$ref": "#/$defs/actionBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "at", "duration", "label", "from", "to"],
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "store" },
            "at": { "type": "number", "minimum": 0 },
            "duration": { "type": "number", "exclusiveMinimum": 0 },
            "label": { "type": "string", "minLength": 1 },
            "from": { "$ref": "#/$defs/point" },
            "to": { "$ref": "#/$defs/point" },
            "result": { "type": "string" }
          }
        }
      ]
    }
  }
}
